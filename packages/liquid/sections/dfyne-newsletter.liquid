<section class="dfyne-newsletter">
  <h2 class="dfyne-newsletter__title">{{ section.settings.title }}</h2>
  <p class="dfyne-newsletter__desc">{{ section.settings.description }}</p>
  <form class="dfyne-newsletter__form" action="/contact#contact_form" method="post" accept-charset="UTF-8">
    <input type="hidden" name="form_type" value="customer">
    <input type="hidden" name="utf8" value="✓">
    <input
      type="email"
      name="contact[email]"
      placeholder="{{ section.settings.placeholder }}"
      class="dfyne-newsletter__input"
      required
      autocomplete="email"
    >
    <button type="submit" class="dfyne-button">
      {{ section.settings.button_label }}
    </button>
  </form>
</section>

{% schema %}
{
  "name": "DFYNE Newsletter",
  "tag": "div",
  "class": "dfyne-newsletter-section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Join the community"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Sign up for exclusive drops, early access and training tips."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "Your email address"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    }
  ],
  "presets": [
    {
      "name": "DFYNE Newsletter"
    }
  ]
}
{% endschema %}

- `--shadow-drawer-side`: -20px 0 40px rgba(0, 0, 0, 0.12)
- `--shadow-focus`: inset 0 0 0 2px var(--color-text-body)
- `--shadow-input`: inset 0 1px 1px #f0f0f0, 0 3px 6px -5px #bbb
- `--shadow-xs`: 0 1px 0 rgba(0, 0, 0, 0.06)
